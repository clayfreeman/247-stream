[Unit]
Description=24/7 stream consumer for %i
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=247-stream
Group=247-stream
EnvironmentFile=/etc/default/stream-consumer
ExecStart=/usr/local/bin/stream-consumer %i
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
